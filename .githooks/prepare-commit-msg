#!/bin/sh
# Strip Cursor-injected attribution from commit messages.
# Cursor's agent shell wrapper appends Co-authored-by / Made-with trailers
# after the agent runs git commit; this hook removes them before finalize.

COMMIT_MSG_FILE="$1"

if [ -f "$COMMIT_MSG_FILE" ]; then
  sed -i '' '/cursoragent@cursor\.com/d' "$COMMIT_MSG_FILE" 2>/dev/null \
    || sed -i '/cursoragent@cursor\.com/d' "$COMMIT_MSG_FILE"
  sed -i '' '/^Made-with: Cursor/d' "$COMMIT_MSG_FILE" 2>/dev/null \
    || sed -i '/^Made-with: Cursor/d' "$COMMIT_MSG_FILE"
  sed -i '' '/^Co-authored-by: Cursor/d' "$COMMIT_MSG_FILE" 2>/dev/null \
    || sed -i '/^Co-authored-by: Cursor/d' "$COMMIT_MSG_FILE"
fi

exit 0
