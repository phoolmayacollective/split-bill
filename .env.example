# Public app URL (used for share links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project: prgjjnudjnaohmeqhhhm (split-bill org)
SUPABASE_URL=https://prgjjnudjnaohmeqhhhm.supabase.co

# Server-side only — get from Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Signs payer session cookies (any random string, 32+ chars)
SESSION_SECRET=your-random-session-secret

# Receipt OCR text parsing — Google AI Studio (server-side only)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Optional — defaults to gemini-flash-latest (2.5-flash-lite may 404 on new keys)
# GEMINI_MODEL=gemini-flash-latest

# Demo-only: shows persona banner when true (use `npm run dev:demo`, not production)
# NEXT_PUBLIC_DEMO_MODE=true

# Narrated demo video — Google Cloud Text-to-Speech (WaveNet)
# 1. Enable Cloud Text-to-Speech API in Google Cloud Console
# 2. Create a service account and download JSON key
# 3. Set absolute path to the key file:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
